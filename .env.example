# --- Required ---

# Password for the KSB Assistant web dashboard (basic auth)
HERMES_PASSWORD=change_me_before_deploy

# Directory where Hermes stores config, models, and agent data
# Maps to the Railway persistent volume mount at /data
HERMES_HOME=/data

# Anthropic API key — used by Hermes to call Claude models
ANTHROPIC_API_KEY=sk-ant-...

# --- Set automatically by Railway ---
# PORT=8080
