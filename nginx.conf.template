worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    sendfile on;
    keepalive_timeout 65;

    # Log to stdout/stderr so Railway captures them
    access_log /dev/stdout;
    error_log  /dev/stderr warn;

    server {
        listen 0.0.0.0:${PORT};
        server_name _;

        # Basic auth enforced on all routes except /health
        auth_basic           "KSB Assistant";
        auth_basic_user_file /etc/nginx/.htpasswd;

        # Unauthenticated healthcheck endpoint for Railway
        location = /health {
            auth_basic off;
            return 200 "ok\n";
            add_header Content-Type text/plain;
        }

        # WebSocket upgrade map
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host 127.0.0.1;
        # Rewrite Origin so hermes' DNS-rebinding guard accepts WebSocket upgrades
        # (browser sends the Railway domain; hermes expects its own loopback origin)
        proxy_set_header Origin "http://127.0.0.1:9119";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Increase timeouts for long-running agent responses
        proxy_read_timeout  300s;
        proxy_send_timeout  300s;
        proxy_connect_timeout 10s;

        # Block OAuth callback/redirect endpoints — API key auth only
        location ~* ^/(auth/callback|oauth|login/oauth) {
            return 403 "OAuth browser login disabled. Use API key via Keys page.";
            add_header Content-Type text/plain;
        }

        location / {
            proxy_pass http://127.0.0.1:9119;
        }
    }
}
