worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    sendfile on;
    keepalive_timeout 65;

    # Log to stdout/stderr so Railway captures them
    access_log /dev/stdout;
    error_log  /dev/stderr warn;

    # Standard WebSocket upgrade map: only emit "Connection: upgrade" when the
    # client actually requested an Upgrade. Hardcoding `Connection "upgrade"`
    # for plain HTTP requests confuses upstreams; this is the canonical pattern.
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    server {
        listen 0.0.0.0:${PORT};
        server_name _;

        # Basic auth enforced on all routes except /health
        auth_basic           "KSB Assistant";
        auth_basic_user_file /etc/nginx/.htpasswd;

        # Unauthenticated healthcheck endpoint for Railway
        location = /health {
            auth_basic off;
            return 200 "ok\n";
            add_header Content-Type text/plain;
        }

        # Headers shared by all proxied locations
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host 127.0.0.1;
        # Rewrite Origin so hermes' DNS-rebinding guard accepts WebSocket upgrades
        # (browser sends the Railway domain; hermes expects its own loopback origin)
        proxy_set_header Origin "http://127.0.0.1:9119";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Increase timeouts for long-running agent responses
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
        proxy_connect_timeout 10s;

        # Block OAuth callback/redirect endpoints — API key auth only
        location ~* ^/(auth/callback|oauth|login/oauth) {
            return 403 "OAuth browser login disabled. Use API key via Keys page.";
            add_header Content-Type text/plain;
        }

        # Long-lived WebSocket / SSE endpoints.
        #
        # auth_basic is disabled here because browsers do NOT include HTTP
        # Basic Auth credentials on `new WebSocket()` requests — there is no
        # 401-challenge round trip for WS upgrades. These endpoints
        # authenticate via `?token=<session-token>` in the URL, which
        # hermes' WebSocket handlers validate against `_SESSION_TOKEN`.
        #
        # IMPORTANT: `proxy_pass ...$request_uri` is required because in
        # regex locations nginx can otherwise drop the query string on the
        # way to the upstream. Without the token, hermes calls `ws.close()`
        # before `ws.accept()`, and Starlette converts that pre-accept close
        # into HTTP 403 with an empty body — matching exactly the symptom
        # we saw in the nginx access log ("403 0").
        location ~ ^/api/(pty|events|pub|ws)$ {
            auth_basic off;
            proxy_pass http://127.0.0.1:9119$request_uri;
            proxy_buffering off;
            proxy_cache off;
        }

        location / {
            proxy_pass http://127.0.0.1:9119;
        }
    }
}
